<%= form_with(model: post,class: "tweet-form") do |form| %>
  <% if post.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:</h2>

      <ul>
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :content, style: "display: block" %>
    <%= form.text_area :content, class: "form content-input", placeholder: "いまどうしてる？" , rows:5 %>
  </div>

  <div>
    <%= form.submit "投稿する", class: "my-custom-btn post-btn" %>
  </div>
<% end %>
